# Copy this file to `.env` for local development. `.env` is gitignored.

# Port the server listens on. Railway injects this automatically in production.
PORT=3001

# MySQL connection string.
#   Local dev: point at the Docker MySQL (see docker-compose.yml). Host port 3307,
#   credentials must match the compose defaults:
#     mysql://boncom:boncom_local_pw@localhost:3307/boncom_estimates
#   Production (Railway): set to Railway's private MYSQL_URL — SAME variable name,
#   different value per environment. Never commit the real value.
# The value below is a DUMMY placeholder, not a working credential.
DATABASE_URL=mysql://user:password@localhost:3307/boncom_estimates
