{
  "name": "boncom-estimates-server",
  "version": "0.1.0",
  "private": true,
  "description": "Backend API for Boncom client estimates",
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "knex": "tsx node_modules/knex/bin/cli.js --knexfile src/data/knexfile.ts",
    "migrate": "npm run knex -- migrate:latest",
    "migrate:rollback": "npm run knex -- migrate:rollback",
    "migrate:make": "npm run knex -- migrate:make -x ts",
    "seed": "npm run knex -- seed:run",
    "seed:make": "npm run knex -- seed:make -x ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "mysql2": "^3.22.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "knex": "^3.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.7"
  }
}
