# Base URL of the Boncom estimates backend API.
# Vite only exposes vars prefixed with VITE_ to client code.
# Local dev falls back to http://localhost:3001 if this is unset (see src/config.ts).
# Production (Vercel) should set this to the deployed Railway URL, e.g.:
#   https://boncom-app-production.up.railway.app
VITE_API_BASE_URL=http://localhost:3001
